#!/usr/bin/env python3
import websocket
import json
import base64
import sys

def take_screenshot(ws_url, output_path):
    ws = websocket.create_connection(ws_url, timeout=30)
    msg_id = [0]
    pending = {}
    
    def on_message(ws, msg):
        data = json.loads(msg)
        mid = data.get("id")
        if mid in pending:
            pending[mid] = data
    
    def send(method, params=None):
        msg_id[0] += 1
        cmd = {"id": msg_id[0], "method": method}
        if params:
            cmd["params"] = params
        pending[msg_id[0]] = None
        ws.send(json.dumps(cmd))
        while pending[msg_id[0]] is None:
            msg = json.loads(ws.recv())
            if msg.get("id") in pending:
                pending[msg["id"]] = msg
        return pending.pop(msg_id[0])
    
    ws.on_message = on_message
    
    send("Page.enable")
    send("Emulation.setDeviceMetricsOverride", {
        "width": 1920, "height": 1080,
        "deviceScaleFactor": 1, "mobile": False
    })
    resp = send("Page.captureScreenshot", {"format": "png"})
    
    # Handle both formats
    if "result" in resp:
        data = resp["result"].get("data")
    else:
        data = resp.get("data")
    
    if data:
        with open(output_path, "wb") as f:
            f.write(base64.b64decode(data))
        print(f"Saved: {output_path}")
    else:
        print(f"Error: {resp}")
    
    ws.close()

if __name__ == "__main__":
    take_screenshot(sys.argv[1], sys.argv[2])
